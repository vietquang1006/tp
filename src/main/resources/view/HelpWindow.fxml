    <Image url="@/images/help_icon.png" />
  </icons>
  <scene>
    <Scene>
      <stylesheets>
        <URL value="@HelpWindow.css" />
      </stylesheets>
      <VBox>
        <children>
          <WebView fx:id="browser" />
        </children>
      </VBox>
    </Scene>
  </scene>
</fx:root>
